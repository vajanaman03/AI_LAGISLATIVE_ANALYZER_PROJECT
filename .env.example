# Legal Document Analyzer API Configuration Variables
# Copy this file to .env and update with your actual values

# ===========================================
# Superwise API Configuration (Required)
# ===========================================

# Superwise API Base URL
# Example: https://api.superwise.ai/
SUPERWISE_API_URL=https://api.superwise.ai/

# Superwise API Version
# Default: v1
SUPERWISE_API_VERSION=v1

# Superwise Application ID
# Get this from your Superwise dashboard
SUPERWISE_APP_ID=your_app_id_here

# ===========================================
# API Timeout Settings (Optional)
# ===========================================

# API Request Timeout (in seconds)
# Default: 60
API_TIMEOUT=60

# Maximum Retry Attempts
# Default: 3
MAX_RETRIES=3

# Delay Between Retries (in seconds)
# Default: 1
RETRY_DELAY=1

# ===========================================
# File Upload Configuration (Optional)
# ===========================================

# Maximum file size for uploads (in MB)
# Default: 10
MAX_FILE_SIZE_MB=10

# ===========================================
# Additional Configuration (Optional)
# ===========================================

# Environment (development, staging, production)
ENVIRONMENT=development

# Debug Mode (true/false)
DEBUG=true

# Log Level (DEBUG, INFO, WARNING, ERROR)
LOG_LEVEL=INFO
